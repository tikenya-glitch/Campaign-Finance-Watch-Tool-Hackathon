<%- include('partials/header') %>

    <main class="max-w-7xl mx-auto p-6 space-y-6">
        <div class="flex justify-between items-end">
            <div>
                <h1 class="text-3xl font-bold text-white">General Ledger</h1>
                <p class="text-xs text-slate-400 italic">Immutable Audit Trail for Campaign Funds</p>
            </div>

            <div class="text-right">
                <p class="text-[10px] text-slate-500 uppercase">Integrity Status</p>
                <p class="text-sm font-bold <%= isBalanced ? 'text-green-400' : 'text-red-400' %>">
                    <%= isBalanced ? '✓ SYSTEM BALANCED' : '⚠ MATH DISCREPANCY' %>
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="p-4 bg-slate-900 border border-slate-800 rounded-lg">
                <p class="text-[10px] text-slate-500 uppercase">Total System Debits</p>
                <p class="text-xl font-bold text-red-400">KES <%= trialBalance.totalDebits.toLocaleString() %>
                </p>
            </div>
            <div class="p-4 bg-slate-900 border border-slate-800 rounded-lg">
                <p class="text-[10px] text-slate-500 uppercase">Total System Credits</p>
                <p class="text-xl font-bold text-green-400">KES <%= trialBalance.totalCredits.toLocaleString() %>
                </p>
            </div>
        </div>

        <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
            <table class="w-full text-xs font-mono">
                <thead class="bg-slate-800 text-slate-400 uppercase">
                    <tr>
                        <th class="p-3 text-left">Date / Ref</th>
                        <th class="p-3 text-left">Account / Entity</th>
                        <th class="p-3 text-right">Debit (Dr)</th>
                        <th class="p-3 text-right">Credit (Cr)</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    <% const grouped={}; ledgerEntries.forEach(entry=> {
                        if (!grouped[entry.transactionId]) {
                        grouped[entry.transactionId] = {
                        details: entry.transaction,
                        entries: []
                        };
                        }
                        grouped[entry.transactionId].entries.push(entry);
                        });

                        Object.values(grouped).forEach(group => {
                        %>
                        <tr class="bg-slate-800/40">
                            <td class="p-3">
                                <span class="text-purple-400 font-bold">
                                    <%= group.details?.mpesaReference || 'INTERNAL' %>
                                </span>
                                <div class="text-[9px] text-slate-500">
                                    <%= new Date(group.details?.createdAt).toLocaleString() %>
                                </div>
                            </td>
                            <td class="p-3 text-[10px] text-slate-500 italic">
                                Type: <%= group.details?.type %> | TX: <%= group.details?.id.slice(0,8) %>
                            </td>
                            <td colspan="2"></td>
                        </tr>

                        <% group.entries.forEach(entry=> { %>
                            <tr class="hover:bg-slate-800/20">
                                <td class="p-3 pl-6 text-slate-600 text-[10px]">Entry: <%= entry.id.slice(0,5) %>
                                </td>
                                <td class="p-3">
                                    <p class="font-bold text-white">
                                        <%= entry.account.user ? entry.account.user.phoneNumber :
                                            (entry.account.vendor?.businessName || "Unknown" ) %>
                                    </p>
                                    <p class="text-[9px] text-slate-500">Acc: <%= entry.accountId.slice(0,13) %>...</p>
                                </td>
                                <td class="p-3 text-right text-red-400">
                                    <%= Number(entry.debit)> 0 ? 'KES ' + Number(entry.debit).toLocaleString() : '—' %>
                                </td>
                                <td class="p-3 text-right text-green-400">
                                    <%= Number(entry.credit)> 0 ? 'KES ' + Number(entry.credit).toLocaleString() : '—'
                                        %>
                                </td>
                            </tr>
                            <% }) %>
                                <% }) %>
                </tbody>
            </table>
        </div>
    </main>