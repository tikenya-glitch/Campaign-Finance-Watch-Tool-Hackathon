<%- include('partials/header') %>

    <body class="bg-slate-50 text-slate-900 font-sans flex items-center justify-center min-h-screen p-4">

        <div class="max-w-md w-full bg-white p-8 border border-slate-200 shadow-xl rounded-2xl">

            <div class="mb-8 flex justify-between items-start">
                <div>
                    <h1 class="text-xl font-bold text-slate-800 tracking-tight">Ledger Gateway</h1>
                    <p class="text-xs text-slate-500 font-medium mt-1">Admin Session: <span
                            class="font-mono text-slate-700">#04332</span></p>
                </div>
                <div
                    class="flex items-center gap-1.5 bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-full border border-emerald-100">
                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                    <span class="text-[10px] font-bold uppercase tracking-wider">Operational</span>
                </div>
            </div>

            <form id="paymentForm" class="space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-xs font-semibold text-slate-700 uppercase tracking-wide">Operation</label>
                        <select name="type" id="type"
                            class="w-full p-2.5 bg-slate-50 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all">
                            <option value="b2c">B2C Disbursement</option>
                            <option value="c2c">Peer Transfer</option>
                            <option value="withdrawal">Vendor Settlement</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-semibold text-slate-700 uppercase tracking-wide">M-Pesa Ref</label>
                        <input type="text" name="mpesaRef" id="mpesaRef" readonly
                            class="w-full p-2.5 bg-slate-100 border border-slate-200 rounded-lg text-sm font-mono text-slate-500 cursor-not-allowed">
                    </div>
                </div>

                <div class="h-px bg-slate-100"></div>

                <div class="space-y-4">
                    <div id="sourceSection" class="space-y-2">
                        <label class="text-xs font-semibold text-slate-700 uppercase tracking-wide">Debit Source
                            (Sender)</label>

                        <div id="vendorSource">
                            <select name="vendorId" id="vendorSourceSelect"
                                class="w-full p-2.5 bg-slate-50 border border-slate-300 rounded-lg text-sm outline-none">
                                <option value="">Select Sending Business/Entity...</option>
                                <% vendors.forEach(v=> { %>
                                    <option value="<%= v.id %>">
                                        <%= v.businessName %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>

                        <div id="userSource" class="hidden">
                            <select name="senderId" id="senderSelect"
                                class="w-full p-2.5 bg-slate-50 border border-slate-300 rounded-lg text-sm outline-none">
                                <option value="">Choose Originating User...</option>
                                <% users.forEach(u=> { %>
                                    <option value="<%= u.id %>">
                                        <%= u.phoneNumber %> — <%= u.name %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>
                    </div>

                    <div id="destinationSection" class="space-y-2">
                        <label class="text-xs font-semibold text-slate-700 uppercase tracking-wide">Credit Target
                            (Receiver)</label>
                        <div id="userTarget">
                            <select name="receiverId" id="receiverSelect"
                                class="w-full p-2.5 bg-slate-50 border border-slate-300 rounded-lg text-sm outline-none">
                                <option value="">Choose Recipient...</option>
                                <% users.forEach(u=> { %>
                                    <option value="<%= u.id %>">
                                        <%= u.phoneNumber %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>
                        <div id="vendorTarget" class="hidden">
                            <select name="vendorId" id="vendorSelect"
                                class="w-full p-2.5 bg-slate-50 border border-slate-300 rounded-lg text-sm outline-none">
                                <option value="">Select Target Vendor...</option>
                                <% vendors.forEach(v=> { %>
                                    <option value="<%= v.id %>">
                                        <%= v.businessName %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-semibold text-slate-700 uppercase tracking-wide">Amount (KES)</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">$</span>
                        <input type="number" name="amount" id="amount" placeholder="0.00" required
                            class="w-full pl-8 p-4 bg-slate-50 border border-slate-300 rounded-xl text-2xl font-bold text-slate-800 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all">
                    </div>
                </div>

                <button type="submit" id="submitBtn"
                    class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-slate-200 active:scale-[0.98]">
                    Execute Transaction
                </button>
            </form>

            <div id="console" class="mt-6 hidden bg-slate-50 p-4 border border-slate-200 rounded-lg">
                <div id="log-flow" class="text-[11px] font-mono space-y-1"></div>
            </div>
        </div>

        <script>
            const form = document.getElementById('paymentForm');
            const typeSelect = document.getElementById('type');
            const mpesaInput = document.getElementById('mpesaRef');
            const logFlow = document.getElementById('log-flow');
            const consoleBox = document.getElementById('console');

            function generateMpesaRef() {
                const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
                let ref = 'R';
                for (let i = 0; i < 9; i++) ref += chars.charAt(Math.floor(Math.random() * chars.length));
                mpesaInput.value = ref;
            }
            generateMpesaRef();

            // UPDATED UI LOGIC: Switches Sender/Receiver based on type
            typeSelect.addEventListener('change', (e) => {
                const type = e.target.value;
                generateMpesaRef();

                // Source Logic
                document.getElementById('vendorSource').classList.toggle('hidden', type !== 'b2c');
                document.getElementById('userSource').classList.toggle('hidden', type === 'b2c');

                // Target Logic
                document.getElementById('userTarget').classList.toggle('hidden', type === 'withdrawal');
                document.getElementById('vendorTarget').classList.toggle('hidden', type !== 'withdrawal');
            });

            form.onsubmit = async (e) => {
                e.preventDefault();
                const type = typeSelect.value;
                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());

                consoleBox.classList.remove('hidden');
                logFlow.innerHTML = `<p class="text-blue-500 font-bold">>> INITIATING_LEDGER_POSTING...</p>`;

                // VALIDATION: Updated to handle Vendor Source in B2C
                if (type === 'b2c' && !data.vendorId) {
                    logFlow.innerHTML += `<p class="text-red-500">_ ERROR: No source business selected.</p>`;
                    return;
                }

                try {
                    const res = await fetch(`/tx/${type}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            ...data,
                            amount: parseFloat(data.amount)
                        })
                    });

                    const result = await res.json();

                    if (result.success) {
                        logFlow.innerHTML += `<p class="text-emerald-600 font-bold">_ SUCCESS: TX_${result.data.mpesaReference} FINALIZED.</p>`;
                        setTimeout(() => window.location.href = `/dashboard/${type}`, 1200);
                    } else {
                        throw new Error(result.error || "REJECTION_BY_LEDGER");
                    }
                } catch (err) {
                    logFlow.innerHTML += `<p class="text-red-600 font-bold">_ CRITICAL: ${err.message}</p>`;
                }
            };
        </script>
    </body>