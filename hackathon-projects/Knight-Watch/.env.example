# Public site URL (for share previews / Open Graph; optional, defaults to Vercel URL)
# NEXT_PUBLIC_APP_URL=https://campaign-finance-wach-tool.vercel.app

# Convex (required for map, reports, signup, login). Use the same deployment you deploy to (npx convex deploy).
# CONVEX_URL is used by server-side login; set it on Vercel too so production login works.
CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Paystack (for Mchango crowdfunding)
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx

# NextAuth (required for login/sign-in to work; replace with a real secret)
# Generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here
# Admin login (for /en/admin/login). Use bcrypt hash, NOT plain password.
# Next.js expands $ in .env — escape each $ as \$ so the hash is preserved.
# Example: email admin@cfwt.com, password Admin123!
# New hash: node -e "const h=require('bcryptjs').hashSync('Admin123!',10); console.log('ADMIN_PASSWORD_HASH='+h.replace(/\$/g,'\\\\$'))"
ADMIN_EMAIL=admin@cfwt.com
ADMIN_PASSWORD_HASH=\$2a\$10\$tHW7vxh5G56WCos6sI5hkOyqqiIjSdzOcS6jgU6fuZZbttkkkR/uK

# Africa's Talking (for USSD and SMS reporting)
# AFRICAS_TALKING_USERNAME=sandbox
# AFRICAS_TALKING_API_KEY=your_api_key
