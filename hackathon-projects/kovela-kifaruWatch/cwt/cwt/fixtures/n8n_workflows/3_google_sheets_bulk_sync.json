      "name": "Read Expenditures Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        480,
        500
      ],
      "notesInFlow": true,
      "notes": "Sheet columns: candidate, category, amount, expenditure_date, vendor, is_digital, description"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst batch = items.map(item => ({\n  candidate: item.json.candidate || '',\n  donor_name: item.json.donor_name || '',\n  donor_type: item.json.donor_type || 'Individual',\n  amount: parseFloat(item.json.amount || 0),\n  contribution_date: item.json.contribution_date || new Date().toISOString().split('T')[0],\n  contribution_type: item.json.contribution_type || 'Cash',\n  notes: item.json.notes || 'Synced from Google Sheets'\n})).filter(r => r.candidate && r.donor_name && r.amount > 0);\n\nreturn [{ json: { type: 'contribution', data: batch, count: batch.length } }];"
      },
      "id": "c1b2c3d4-3333-4000-8000-000000000004",
      "name": "Format Contributions Batch",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        740,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst batch = items.map(item => ({\n  candidate: item.json.candidate || '',\n  category: item.json.category || 'Other',\n  amount: parseFloat(item.json.amount || 0),\n  expenditure_date: item.json.expenditure_date || new Date().toISOString().split('T')[0],\n  vendor: item.json.vendor || '',\n  is_digital: (item.json.is_digital === '1' || item.json.is_digital === 'true' || item.json.is_digital === true) ? 1 : 0,\n  description: item.json.description || 'Synced from Google Sheets'\n})).filter(r => r.candidate && r.amount > 0);\n\nreturn [{ json: { type: 'expenditure', data: batch, count: batch.length } }];"
      },
      "id": "c1b2c3d4-3333-4000-8000-000000000005",
      "name": "Format Expenditures Batch",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
