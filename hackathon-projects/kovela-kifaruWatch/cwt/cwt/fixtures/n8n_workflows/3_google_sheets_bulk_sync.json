      "name": "Merge Results",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1260,
        340
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet cCreated = 0, cUpdated = 0, eCreated = 0, eUpdated = 0;\n\nfor (const item of items) {\n  const msg = item.json.message || item.json;\n  cCreated += msg.created || 0;\n  cUpdated += msg.updated || 0;\n}\n\nreturn [{\n  json: {\n    summary: 'Sync complete: ' + cCreated + ' created, ' + cUpdated + ' updated',\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
